---
interface Stat {
  label: string;
}

interface Link {
  label: string;
  href: string;
}

interface Props {
  id: string;
  name: string;
  tagline: string;
  description: string;
  features: string[];
  stats: Stat[];
  links: Link[];
  icon?: string;
  badge?: string;
}

const { id, name, tagline, description, features, stats, links, icon = '⬡', badge } = Astro.props;
---

<article id={id} class="group relative rounded-2xl border border-[#0d2e3a] bg-[#0d1f2d]/50 p-6 lg:p-8 hover:border-[#00c8c8]/50 hover:shadow-glow transition-all duration-300 scroll-mt-24">
  <!-- Badge -->
  {badge && (
    <span class="absolute top-4 right-4 px-2.5 py-1 rounded-full text-xs font-medium bg-[#00c8c8]/20 text-[#818cf8] border border-[#00c8c8]/30">
      {badge}
    </span>
  )}

  <!-- Header -->
  <div class="flex items-start gap-4 mb-4">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#00c8c8]/20 to-[#00a8d4]/20 border border-[#00c8c8]/30 flex items-center justify-center text-2xl flex-shrink-0">
      {icon}
    </div>
    <div>
      <h2 class="text-xl font-bold text-white">{name}</h2>
      <p class="text-sm text-[#818cf8] font-medium mt-0.5">{tagline}</p>
    </div>
  </div>

  <!-- Description -->
  <p class="text-gray-400 text-sm leading-relaxed mb-5">{description}</p>

  <!-- Features -->
  <div class="mb-5">
    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Features</h3>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
      {features.map(f => (
        <li class="flex items-start gap-2 text-sm text-gray-300">
          <span class="text-[#00c8c8] mt-0.5 flex-shrink-0">▸</span>
          {f}
        </li>
      ))}
    </ul>
  </div>

  <!-- Stats -->
  <div class="flex flex-wrap gap-2 mb-5">
    {stats.map(stat => (
      <span class="px-2.5 py-1 rounded-lg bg-[#0a0a0f] border border-[#0d2e3a] text-xs font-mono text-gray-300">
        {stat.label}
      </span>
    ))}
  </div>

  <!-- Links -->
  <div class="flex flex-wrap gap-3">
    {links.map(link => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border border-[#0d2e3a] text-gray-300 hover:text-white hover:border-[#00c8c8]/60 hover:bg-[#00c8c8]/10 transition-all duration-200"
      >
        {link.label}
        <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    ))}
  </div>
</article>

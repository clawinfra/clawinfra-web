---
import Layout from '../layouts/Layout.astro';

const phases = [
  {
    id: 'phase-1',
    status: 'complete',
    statusLabel: 'Complete',
    statusEmoji: '✅',
    title: 'Phase 1 — Foundation',
    period: 'Shipped',
    items: [
      'ClawChain testnet live with 3 validators',
      '12 pallets shipped and security-audited',
      'Block #260,000+ reached on testnet',
      'EvoClaw v0.6.0 released with SKILLRL',
      'clawchain-sdk v1.0.0 published to npm',
      'clawkeyring v0.1.0 — encrypted key management',
    ],
  },
  {
    id: 'phase-2',
    status: 'active',
    statusLabel: 'In Progress',
    statusEmoji: '🔄',
    title: 'Phase 2 — Ecosystem',
    period: 'In Progress',
    items: [
      'Multi-validator mainnet launch',
      'EvoClaw v0.7 with enhanced SKILLRL',
      'Agent marketplace beta',
      'IBC cross-chain bridge live',
      'Developer documentation portal',
      'SDK v2.0 with streaming support',
    ],
  },
  {
    id: 'phase-3',
    status: 'upcoming',
    statusLabel: 'Planned',
    statusEmoji: '⏳',
    title: 'Phase 3 — Scale',
    period: 'Planned',
    items: [
      'Polkadot parachain slot',
      'Enterprise agent deployments',
      'On-chain token economics',
      'Agent DAO governance',
      'Cross-chain agent identity federation',
      'Decentralized agent marketplace',
    ],
  },
];
---

<Layout
  title="Roadmap"
  description="ClawInfra's development roadmap from foundation to scale."
>
  <section class="pt-32 pb-24 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#00c8c8]/40 bg-[#00c8c8]/10 text-sm text-[#818cf8] mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Phase 2 in progress
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">Roadmap</h1>
      <p class="text-gray-400 max-w-lg mx-auto text-lg">
        Building agent-native infrastructure one phase at a time — transparently, in the open.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-[#00c8c8] via-[#00c8c8]/50 to-[#0d2e3a]"></div>

      <div class="flex flex-col gap-12">
        {phases.map((phase, idx) => (
          <div id={phase.id} class="relative flex gap-6 sm:gap-10 scroll-mt-24">
            <!-- Timeline dot -->
            <div class={`relative z-10 flex-shrink-0 w-12 h-12 sm:w-16 sm:h-16 rounded-full border-2 flex items-center justify-center text-xl sm:text-2xl
              ${phase.status === 'complete' ? 'border-green-500 bg-green-500/10' :
                phase.status === 'active' ? 'border-[#00c8c8] bg-[#00c8c8]/10 shadow-glow' :
                'border-[#0d2e3a] bg-[#0d1f2d]'}`}>
              {phase.statusEmoji}
            </div>

            <!-- Content -->
            <div class={`flex-1 rounded-2xl border p-6 lg:p-8 transition-all duration-300
              ${phase.status === 'complete' ? 'border-green-500/30 bg-green-500/5' :
                phase.status === 'active' ? 'border-[#00c8c8]/50 bg-[#00c8c8]/5 shadow-glow' :
                'border-[#0d2e3a] bg-[#0d1f2d]/50 opacity-70'}`}>

              <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
                <div>
                  <h2 class="text-xl sm:text-2xl font-bold text-white">{phase.title}</h2>
                  <p class="text-sm text-gray-500 mt-0.5">{phase.period}</p>
                </div>
                <span class={`px-3 py-1 rounded-full text-xs font-semibold
                  ${phase.status === 'complete' ? 'bg-green-500/20 text-green-400 border border-green-500/30' :
                    phase.status === 'active' ? 'bg-[#00c8c8]/20 text-[#818cf8] border border-[#00c8c8]/40' :
                    'bg-gray-800 text-gray-500 border border-gray-700'}`}>
                  {phase.statusLabel}
                </span>
              </div>

              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                {phase.items.map(item => (
                  <li class="flex items-start gap-2 text-sm text-gray-300">
                    <span class={`mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full
                      ${phase.status === 'complete' ? 'bg-green-400' :
                        phase.status === 'active' ? 'bg-[#00c8c8]' :
                        'bg-gray-600'}`}></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom note -->
    <div class="mt-16 rounded-2xl border border-[#0d2e3a] bg-[#0d1f2d]/30 p-6 text-center">
      <p class="text-gray-400 text-sm">
        Have ideas or want to influence the roadmap?
        <a href="https://github.com/clawinfra" target="_blank" rel="noopener noreferrer" class="text-[#00c8c8] hover:text-[#00a8d4] ml-1 transition-colors">Open an issue on GitHub →</a>
      </p>
    </div>
  </section>
</Layout>
